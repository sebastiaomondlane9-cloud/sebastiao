rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isParticipant(chatId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Chats ---
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && 
                      request.resource.data.participants.size() == 2 &&
                      request.auth.uid in request.resource.data.participants &&
                      isValidId(chatId);
      allow update: if isSignedIn() && 
                      request.auth.uid in resource.data.participants &&
                      request.resource.data.participants == resource.data.participants &&
                      request.resource.data.chatId == resource.data.chatId;

      // --- Messages Subcollection ---
      match /messages/{messageId} {
        allow read: if isParticipant(chatId);
        allow create: if isParticipant(chatId) && 
                        request.resource.data.senderId == request.auth.uid &&
                        request.resource.data.text is string &&
                        request.resource.data.text.size() <= 1000 &&
                        request.resource.data.timestamp == request.time;
      }
    }
  }
}
